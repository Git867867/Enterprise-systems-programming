<Window x:Class="LibraryManagement.AuthorsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление авторами" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Авторы" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="AuthorsGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Имя" Binding="{Binding FirstName}" Width="120"/>
                <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="120"/>
                <DataGridTextColumn Header="Год рождения" Binding="{Binding BirthYear}" Width="100"/>
                <DataGridTextColumn Header="Страна" Binding="{Binding Country}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                <Button Content="Добавить" Width="80" Height="30" Margin="5" Click="AddAuthor_Click"/>
                <Button Content="Изменить" Width="80" Height="30" Margin="5" Click="EditAuthor_Click"/>
                <Button Content="Удалить" Width="80" Height="30" Margin="5" Click="DeleteAuthor_Click"/>
            </StackPanel>
            <Button Content="Закрыть" Grid.Column="3" Width="80" Height="30" Margin="5" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>