<Window x:Class="LibraryManagement.GenresWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление жанрами" Height="400" Width="500"
        WindowStartupLocation="CenterOwner">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Жанры" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

        <DataGrid x:Name="GenresGrid" Grid.Row="1" AutoGenerateColumns="False" 
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                <Button Content="Добавить" Width="80" Height="30" Margin="5" Click="AddGenre_Click"/>
                <Button Content="Изменить" Width="80" Height="30" Margin="5" Click="EditGenre_Click"/>
                <Button Content="Удалить" Width="80" Height="30" Margin="5" Click="DeleteGenre_Click"/>
            </StackPanel>
            <Button Content="Закрыть" Grid.Column="3" Width="80" Height="30" Margin="5" Click="Close_Click"/>
        </Grid>
    </Grid>
</Window>