<Window x:Class="LibraryManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление библиотекой" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="Библиотека книг" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" Grid.Row="0"/>

        <!-- Панель фильтрации -->
        <GroupBox Header="Фильтрация" Grid.Row="1" Margin="0,0,0,10">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Label Content="Поиск по названию:" Grid.Column="0" VerticalAlignment="Center"/>
                <TextBox x:Name="SearchTextBox" Grid.Column="1" Margin="5" Height="25" TextChanged="SearchTextBox_TextChanged"/>

                <Label Content="Автор:" Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="AuthorFilterCombo" Grid.Column="3" Margin="5" Height="25" 
                        DisplayMemberPath="FullName" SelectionChanged="FilterCombo_SelectionChanged"/>

                <Label Content="Жанр:" Grid.Column="4" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <ComboBox x:Name="GenreFilterCombo" Grid.Column="5" Margin="5" Height="25" 
                        DisplayMemberPath="Name" SelectionChanged="FilterCombo_SelectionChanged"/>
                
                <Button Content="Сбросить" Grid.Column="6" Margin="5" Width="80" Height="25" Click="ResetFilter_Click"/>
            </Grid>
        </GroupBox>

        <!-- для книг -->
        <DataGrid x:Name="BooksDataGrid" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" 
                  SelectionMode="Single" Margin="0,0,0,10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="40"/>
                <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                <DataGridTextColumn Header="Автор" Binding="{Binding Author.FullName}" Width="150"/>
                <DataGridTextColumn Header="Жанр" Binding="{Binding Genre.Name}" Width="120"/>
                <DataGridTextColumn Header="Год" Binding="{Binding PublishYear}" Width="60"/>
                <DataGridTextColumn Header="ISBN" Binding="{Binding ISBN}" Width="120"/>
                <DataGridTextColumn Header="В наличии" Binding="{Binding QuantityInStock}" Width="70"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Панель кнопок и информация -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Добавить книгу" Grid.Column="0" Width="120" Height="30" Margin="0,0,5,0" Click="AddBook_Click"/>
            <Button Content="Редактировать" Grid.Column="1" Width="100" Height="30" Margin="0,0,5,0" Click="EditBook_Click"/>
            <Button Content="Удалить" Grid.Column="2" Width="80" Height="30" Margin="0,0,5,0" Click="DeleteBook_Click"/>
            
            <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,10,0">
                <Button Content="Авторы" Width="80" Height="30" Margin="5,0" Click="ManageAuthors_Click"/>
                <Button Content="Жанры" Width="80" Height="30" Margin="5,0" Click="ManageGenres_Click"/>
            </StackPanel>

            <TextBlock x:Name="TotalBooksText" Grid.Column="4" VerticalAlignment="Center" 
                       Text="Всего книг: 0" FontWeight="Bold" Margin="10,0"/>
        </Grid>
    </Grid>
</Window>