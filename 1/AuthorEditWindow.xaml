<Window x:Class="LibraryManagement.AuthorEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Автор" Height="250" Width="350"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Content="Имя:" Grid.Row="0" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="FirstNameBox" Grid.Row="0" Grid.Column="1" Margin="5" Height="25"/>

        <Label Content="Фамилия:" Grid.Row="1" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="LastNameBox" Grid.Row="1" Grid.Column="1" Margin="5" Height="25"/>

        <Label Content="Год рождения:" Grid.Row="2" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="BirthYearBox" Grid.Row="2" Grid.Column="1" Margin="5" Height="25"/>

        <Label Content="Страна:" Grid.Row="3" Grid.Column="0" Margin="5"/>
        <TextBox x:Name="CountryBox" Grid.Row="3" Grid.Column="1" Margin="5" Height="25"/>

        <Grid Grid.Row="4" Grid.ColumnSpan="2" Margin="0,20,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="OK" Grid.Column="1" Width="80" Height="30" Margin="5" Click="Ok_Click"/>
            <Button Content="Отмена" Grid.Column="2" Width="80" Height="30" Margin="5" Click="Cancel_Click"/>
        </Grid>
    </Grid>
</Window>